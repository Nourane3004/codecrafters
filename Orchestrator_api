@app.get("/health")
def health():
    return {"status": "ok", "service": "orchestrator_api", "version": "3.0.0"}


@app.post("/analyse/plan")
async def get_plan(
    input_type:      str  = Form(...),
    content_nature:  str  = Form(...),
    analysis_goals:  str  = Form(...),   # JSON array string
    source_url:      str  = Form(""),
    post_text:       str  = Form(""),
):
    """
    Compute the agent activation plan without running any agents.
    The UI calls this at Step 4 so the user can review the plan before running.
    """
    try:
        goals: list[str] = json.loads(analysis_goals)
    except (json.JSONDecodeError, ValueError):
        goals = []

    plan = _compute_plan(
        input_type=input_type,
        content_nature=content_nature,
        analysis_goals=goals,
        source_url=source_url,
        post_text=post_text,
    )
    return plan


@app.post("/analyse")
async def analyse(
    input_type:      str            = Form(...),
    content_nature:  str            = Form(...),
    analysis_goals:  str            = Form(...),   # JSON array string
    source_url:      str            = Form(""),
    post_text:       str            = Form(""),
    platform:        str            = Form(""),
    author_handle:   str            = Form(""),
    file:            Optional[UploadFile] = File(None),
):
    """
    Run the full agent pipeline and return a UI-ready result.

    The UI sends:
      - file          (for image / video / document uploads)
      - source_url    (for URL inputs or the original post URL)
      - input_type    image | video | document | url
      - content_nature  social_post_screenshot | news_article | etc.
      - analysis_goals  JSON array of goal strings
    """
    try:
        goals: list[str] = json.loads(analysis_goals)
    except (json.JSONDecodeError, ValueError):
        goals = []

    # Build plan (needed for UI metadata even after the run)
    plan = _compute_plan(
        input_type=input_type,
        content_nature=content_nature,
        analysis_goals=goals,
        source_url=source_url,
        post_text=post_text,
    )

    # Read file bytes if a file was uploaded
    file_bytes: Optional[bytes] = None
    source_ref: str = source_url or "upload"

    if file is not None:
        file_bytes = await file.read()
        source_ref = file.filename or "upload"
        # If input_type was sent as "url" but a file is also present, prefer the file
        if input_type == "url" and file_bytes:
            input_type = _detect_input_type(source_ref)

    # For URL-only submissions (no file), pass the URL as both source_ref and url param
    url_param: Optional[str] = None
    if input_type == "url":
        url_param  = source_url or None
        source_ref = source_url or "url-input"

    if not file_bytes and input_type != "url":
        raise HTTPException(
            status_code=400,
            detail=(
                f"No file uploaded for input_type='{input_type}'. "
                "Send a file in the 'file' field, or set input_type to 'url'."
            ),
        )

    # ── Run the Prefect orchestrator flow ──────────────────────────────────────
    t0 = time.perf_counter()
    try:
        result: PipelineResult = await analyse_content(
            source_ref=source_ref,
            input_type=input_type,
            file_bytes=file_bytes,
            url=url_param,
        )
    except Exception as exc:
        logger.exception("Orchestrator flow failed")
        raise HTTPException(
            status_code=500,
            detail=f"Pipeline error: {str(exc)}",
        ) from exc

    t_ms = int((time.perf_counter() - t0) * 1000)

    # Enrich the audit trail with UI-level context that the orchestrator doesn't know about
    if isinstance(result.audit_trail, dict):
        result.audit_trail["input_type"]      = input_type
        result.audit_trail["content_nature"]  = content_nature
        result.audit_trail["analysis_goals"]  = goals

    return _pipeline_result_to_ui(result, plan, t_ms)



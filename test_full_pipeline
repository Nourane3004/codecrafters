async def test_fusion_edge_cases():
    header("TEST 8 — Fusion edge cases")
    from Agents.evidence_fusion import fuse_evidence, DecisionEngine
    from Agents.claim_verifier    import ClaimVerifyResult
    from Agents.source_cred_agent import SourceCredibilityAgent, SourceCredibilityResult
    from Agents.context_agent     import ContextAgent
    from Agents.network_agent     import analyse_network
    from Agents.linguistic_agent  import analyse_linguistics

    nfo       = _make_nfo("document")
    extractor = _make_heuristic_extractor()
    ctx_agent = ContextAgent(use_mock=True)

    # ── Case A: benign ──────────────────────────────────────────────
    benign_text   = "The quarterly earnings report showed stable growth of 3% year-over-year."
    b_extract     = await extractor.extract(benign_text, source_type="document")
    b_context     = await ctx_agent.run(nfo, b_extract.claims)
    b_source      = await SourceCredibilityAgent().run(nfo)
    b_network     = analyse_network(source_type="document", url="", extracted_text=benign_text)
    b_linguistic  = analyse_linguistics(extracted_text=benign_text, source_type="document")
    b_verify      = ClaimVerifyResult(
        input_type="DOCUMENT", source_ref="test", dedup_hash="b"*64,
        quality_passed=True, claims=[], verified_claims=[], retrieved_chunks=[],
        overall_support_score=0.9, overall_contradiction_score=0.05, agent_errors=[],
    )
    benign_result = fuse_evidence(
        nfo=nfo, claim_extraction=b_extract, claim_verification=b_verify,
        source_cred=b_source, image_forensics=None, video_forensics=None,
        context=b_context, network=b_network, linguistic=b_linguistic,
    )
    ok("benign_risk",  benign_result.risk_score)
    ok("benign_band",  benign_result.risk_band)

    # ── Case B: high risk ───────────────────────────────────────────
    h_extract    = await extractor.extract(SAMPLE_TEXT, source_type="url")
    h_context    = await ctx_agent.run(nfo, h_extract.claims)
    h_network    = analyse_network(
        source_type="url", url="http://1.2.3.4/redirect?r=fake",
        extracted_text="Send this to everyone! Share before deleted! Forward to 10 friends!",
    )
    h_linguistic = analyse_linguistics(
        extracted_text=SAMPLE_TEXT * 3,
        title="SHOCKING SECRET THEY DON'T WANT YOU TO KNOW — share before deleted!!",
        source_type="url",
    )
    h_source     = SourceCredibilityResult(
        source_ref="test", input_type="URL",
        overall_score=0.05, is_known_fake_news=True,
        red_flags=["known_fake_news"],
    )
    h_verify     = ClaimVerifyResult(
        input_type="URL", source_ref="test", dedup_hash="c"*64,
        quality_passed=True, claims=[], verified_claims=[], retrieved_chunks=[],
        overall_support_score=0.0, overall_contradiction_score=0.95, agent_errors=[],
    )
    high_result  = fuse_evidence(
        nfo=nfo, claim_extraction=h_extract, claim_verification=h_verify,
        source_cred=h_source, image_forensics=None, video_forensics=None,
        context=h_context, network=h_network, linguistic=h_linguistic,
    )
    ok("high_risk",    high_result.risk_score)
    ok("high_band",    high_result.risk_band)

    check("high > benign", high_result.risk_score,
          high_result.risk_score > benign_result.risk_score)

    engine = DecisionEngine()
    ok("benign_action", engine.decide(benign_result).action)
    ok("high_action",   engine.decide(high_result).action)

    print(f"\n  {PASS} — Fusion edge cases OK")
    _results["FusionEdgeCases"] = "PASS"



async def test_fusion_edge_cases():
    header("TEST 8 — Fusion edge cases")
    from evidence_fusion import fuse_evidence, DecisionEngine
    from Agents.claim_extractor import ClaimExtractor, ClaimExtractionResult
    from Agents.claim_verifier import ClaimVerifyResult
    from Agents.context_agent import ContextAgent
    from Agents.source_cred_agent import SourceCredibilityAgent
    from Agents.network_agent import analyse_network
    from Agents.linguistic_agent import analyse_linguistics

    nfo = _make_nfo("document")
    extractor = ClaimExtractor(provider="openai_compat")

    # Case A — completely benign content
    benign_text = "The quarterly earnings report showed stable growth of 3% year-over-year."
    benign_extract = await extractor.extract(benign_text, source_type="document")
    context_agent = ContextAgent(use_mock=True)
    source_agent  = SourceCredibilityAgent()
    benign_context = await context_agent.run(nfo, benign_extract.claims)
    benign_source  = await source_agent.run(nfo)
    benign_network = analyse_network(source_type="document", url="", extracted_text=benign_text)
    benign_ling    = analyse_linguistics(extracted_text=benign_text, source_type="document")

    benign_verify = ClaimVerifyResult(
        input_type="DOCUMENT", source_ref="test", dedup_hash="b"*64,
        quality_passed=True, claims=[], verified_claims=[], retrieved_chunks=[],
        overall_support_score=0.9, overall_contradiction_score=0.05, agent_errors=[],
    )

    benign_result = fuse_evidence(
        nfo=nfo, claim_extraction=benign_extract, claim_verification=benign_verify,
        source_cred=benign_source, image_forensics=None, video_forensics=None,
        context=benign_context, network=benign_network, linguistic=benign_ling,
    )
    ok("benign_risk_score", benign_result.risk_score)
    ok("benign_risk_band",  benign_result.risk_band)

    # Case B — all signals fire with high risk
    high_risk_verify = ClaimVerifyResult(
        input_type="DOCUMENT", source_ref="test", dedup_hash="c"*64,
        quality_passed=True, claims=[], verified_claims=[], retrieved_chunks=[],
        overall_support_score=0.0, overall_contradiction_score=0.95, agent_errors=[],
    )
    high_ling = analyse_linguistics(
        extracted_text=SAMPLE_TEXT * 3,
        title="SHOCKING SECRET THEY DON'T WANT YOU TO KNOW — share before deleted!!",
        source_type="url",
    )
    from Agents.source_cred_agent import SourceCredibilityResult
    fake_source = SourceCredibilityResult(
        source_ref="test", input_type="URL",
        overall_score=0.05, is_known_fake_news=True,
        red_flags=["known_fake_news"],
    )
    high_network = analyse_network(
        source_type="url", url="http://1.2.3.4/redirect?r=fake",
        extracted_text="Send this to everyone! Share before deleted! Forward to 10 friends!",
    )
    high_extract = await extractor.extract(SAMPLE_TEXT, source_type="url")
    high_context = await context_agent.run(nfo, high_extract.claims)

    high_result = fuse_evidence(
        nfo=nfo, claim_extraction=high_extract, claim_verification=high_risk_verify,
        source_cred=fake_source, image_forensics=None, video_forensics=None,
        context=high_context, network=high_network, linguistic=high_ling,
    )
    ok("high_risk_score",  high_result.risk_score)
    ok("high_risk_band",   high_result.risk_band)
    check("high_risk_elevated", high_result.risk_score,
          high_result.risk_score > benign_result.risk_score)

    engine = DecisionEngine()
    benign_decision = engine.decide(benign_result)
    high_decision   = engine.decide(high_result)
    ok("benign_action", benign_decision.action)
    ok("high_action",   high_decision.action)

    print(f"\n  {PASS} — Fusion edge cases OK")
    _results["FusionEdgeCases"] = "PASS"



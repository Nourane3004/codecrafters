async def main():
    # Unit tests — agents
    await _run_async("ClaimExtractor",    test_claim_extractor)
    await _run_async("ContextAgent",      test_context_agent)
    await _run_async("SourceCredibility", test_source_cred_agent)
    _run("NetworkAgent",                  test_network_agent)
    _run("LinguisticAgent",               test_linguistic_agent)
    _run("ImageForensics",                test_image_forensics)

    # Fusion layer
    await _run_async("EvidenceFusion",    test_evidence_fusion)
    await _run_async("FusionEdgeCases",   test_fusion_edge_cases)

    # Full pipeline
    await _run_async("Orchestrator",      test_orchestrator)

    # ── Summary ──────────────────────────────────────────────────
    print(f"\n{BOLD}{'='*60}")
    print("  SUMMARY")
    print(f"{'='*60}{RESET}")
    for name, status in _results.items():
        symbol = {
            "PASS": PASS, "SKIP": SKIP, "FAIL": FAIL,
        }.get(status, status)
        print(f"  {name:<22} {symbol}")

    failed  = [n for n, s in _results.items() if s == "FAIL"]
    skipped = [n for n, s in _results.items() if s == "SKIP"]

    if failed:
        print(f"\n{RED}✗ {len(failed)} test(s) FAILED: {', '.join(failed)}{RESET}\n")
        sys.exit(1)
    else:
        note = f"  ({len(skipped)} skipped — missing optional deps)" if skipped else ""
        print(f"\n{GREEN}✓ All tests passed.{RESET}{note}\n")


if __name__ == "__main__":
    asyncio.run(main())
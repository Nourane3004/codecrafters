async def test_orchestrator():
    header("TEST 9 — Full Orchestrator (integration)")

    # The orchestrator calls Prefect tasks. In test mode we call the underlying
    # flow directly — Prefect handles execution without a running server.
    try:
        from orchestrator import analyse_content
    except ImportError as e:
        print(f"  {SKIP} — Could not import orchestrator: {e}")
        _results["Orchestrator"] = "SKIP"
        return

    # ── 9a. Document input (no system deps needed) ────────────────
    print("  Running document flow...")
    result = await analyse_content(
        source_ref="smoke_test_doc.txt",
        input_type="document",
        file_bytes=SAMPLE_DOC_BYTES,
    )
    check("action_valid",  result.action,
          result.action in ("auto-allow", "flag-review", "auto-block"))
    check("risk_score",    result.risk_score, 0.0 <= result.risk_score <= 1.0)
    check("risk_band",     result.risk_band, result.risk_band in ("GREEN","AMBER","ORANGE","RED"))
    check("has_audit",     result.audit_trail, bool(result.audit_trail))
    ok("doc_action",       result.action)
    ok("doc_risk",         result.risk_score)

    # ── 9b. Quality gate rejection path ──────────────────────────
    print("  Running quality gate rejection path...")
    bad_result = await analyse_content(
        source_ref="empty.txt",
        input_type="document",
        file_bytes=b"",
    )
    check("bad_action", bad_result.action,
          bad_result.action in ("auto-block", "flag-review"))

    # ── 9c. Image input (requires Pillow) ─────────────────────────
    try:
        from PIL import Image as _pil  # noqa
        print("  Running image flow...")
        img_bytes = _make_jpeg_bytes(300, 300)
        img_result = await analyse_content(
            source_ref="test.jpg",
            input_type="image",
            file_bytes=img_bytes,
        )
        check("img_action", img_result.action,
              img_result.action in ("auto-allow","flag-review","auto-block"))
        ok("img_action",    img_result.action)
        ok("img_risk",      img_result.risk_score)
    except ImportError:
        print(f"  {SKIP} — Pillow not installed, image flow skipped")

    print(f"\n  {PASS} — Orchestrator integration test OK")
    _results["Orchestrator"] = "PASS"



SAMPLE_TEXT = textwrap.dedent("""\
    Breaking: Scientists at ITER announced that fusion energy will power all homes
    by 2025. The government doesn't want you to know this secret. Share before deleted!
    100% of experts agree this is a revolutionary breakthrough. Coal power plants
    will be fully phased out by 2025 according to anonymous sources.
""")

SAMPLE_DOC_BYTES = SAMPLE_TEXT.encode("utf-8")


def _make_jpeg_bytes(w: int = 300, h: int = 300, color=(180, 100, 80)) -> bytes:
    from PIL import Image
    img = Image.new("RGB", (w, h), color=color)
    buf = io.BytesIO()
    img.save(buf, format="JPEG")
    return buf.getvalue()


def _make_nfo(input_type: str = "document"):
    """Minimal NormalizedFeatureObject for agent unit tests."""
    from Preprocessing.app.models.feature_object import (
        NormalizedFeatureObject, InputType,
        DocumentData, TextExtract, LayoutInfo, DocMetadata,
        PageScrape, MetaExtract, DomainInfo,
        ImageMetadata, OCRResult, EXIFData,
    )
    from datetime import datetime, timezone

    it = InputType(input_type)
    common = dict(
        input_type=it,
        source_ref="test_source",
        text=SAMPLE_TEXT,
        language="en",
        quality_passed=True,
        quality_reason="smoke_test",
        dedup_hash="a" * 64,
        processed_at=datetime.now(timezone.utc).isoformat(),
    )

    if it == InputType.DOCUMENT:
        doc_data = DocumentData(
            text_extract=TextExtract(raw_text=SAMPLE_TEXT, extraction_method="plain"),
            layout=LayoutInfo(word_count=len(SAMPLE_TEXT.split())),
            doc_meta=DocMetadata(),
        )
        return NormalizedFeatureObject(**common, document_data=doc_data)

    if it == InputType.URL:
        url_data = PageScrape(
            status_code=200,
            final_url="https://example-news.xyz/story",
            raw_text=SAMPLE_TEXT,
            meta=MetaExtract(title="Breaking Fusion Energy News"),
            domain_info=DomainInfo(domain="example-news.xyz", age_days=15, is_new_domain=True),
        )
        return NormalizedFeatureObject(**common, url_data=url_data)

    if it == InputType.IMAGE:
        img_meta = ImageMetadata(
            width=300, height=300, format="JPEG",
            ocr=OCRResult(raw_text=SAMPLE_TEXT, confidence=0.88),
            exif=EXIFData(exif_stripped=True),
        )
        return NormalizedFeatureObject(**common, image_meta=img_meta)

    return NormalizedFeatureObject(**common)


def _make_heuristic_extractor():
    """
    Returns a ClaimExtractor that ALWAYS uses the heuristic fallback.
    No Ollama / LLM server needed.
    """
    from Agents.claim_extractor import ClaimExtractor

    class HeuristicOnlyExtractor(ClaimExtractor):
        async def extract(self, text, source_type="unknown"):
            if not text or not text.strip():
                from Agents.claim_extractor import ClaimExtractionResult
                return ClaimExtractionResult(
                    success=False, extraction_method="failed", error="No text provided",
                    reasoning_notes=["Input text was empty"],
                )
            return self._extract_with_heuristics(text, source_type)

    return HeuristicOnlyExtractor(provider="openai_compat")



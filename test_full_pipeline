async def test_claim_extractor():
    header("TEST 1 — ClaimExtractor agent")
    from Agents.claim_extractor import ClaimExtractor, ClaimExtractionResult

    extractor = ClaimExtractor(provider="openai_compat")

    # Test with heuristic fallback (no LLM server needed)
    result: ClaimExtractionResult = await extractor.extract(SAMPLE_TEXT, source_type="document")

    check("success",         result.success,         result.success is True)
    check("total_claims",    result.total_claims,     result.total_claims > 0)
    check("extraction_method", result.extraction_method, result.extraction_method in ("llm","heuristic"))
    ok("high_risk_claims",   result.high_risk_claims)
    ok("dominant_types",     result.dominant_claim_types)
    ok("reasoning_notes",    result.reasoning_notes)
    check("confidence",      result.confidence_contribution,
          0.0 <= result.confidence_contribution <= 1.0)

    # Empty text → graceful failure
    empty_result = await extractor.extract("", source_type="document")
    check("empty_text_handled", empty_result.success, empty_result.success is False)

    print(f"\n  {PASS} — ClaimExtractor OK")
    _results["ClaimExtractor"] = "PASS"



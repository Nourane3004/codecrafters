# Helpers
# ══════════════════════════════════════════════════════════════════

def header(title: str) -> None:
    print(f"\n{BOLD}{CYAN}{'='*60}{RESET}")
    print(f"{BOLD}{CYAN}  {title}{RESET}")
    print(f"{BOLD}{CYAN}{'='*60}{RESET}")

def row(label: str, value) -> None:
    print(f"  {label:<26}: {value}")

def ok(label: str, value) -> None:
    row(label, value)

def check(label: str, value, condition: bool) -> None:
    row(label, value)
    if not condition:
        raise AssertionError(f"{label} failed — got: {value!r}")

def _run(name: str, fn) -> None:
    try:
        fn()
    except Exception:
        _results[name] = "FAIL"
        print(f"\n  {FAIL} — {name}:")
        traceback.print_exc()

async def _run_async(name: str, fn) -> None:
    try:
        await fn()
    except Exception:
        _results[name] = "FAIL"
        print(f"\n  {FAIL} — {name}:")
        traceback.print_exc()



async def test_evidence_fusion():
    header("TEST 7 — EvidenceFusion layer")
    from evidence_fusion import fuse_evidence, FusionResult, DecisionEngine, PipelineResult
    from Agents.claim_extractor import ClaimExtractor
    from Agents.context_agent import ContextAgent
    from Agents.source_cred_agent import SourceCredibilityAgent
    from Agents.network_agent import analyse_network
    from Agents.linguistic_agent import analyse_linguistics

    nfo = _make_nfo("url")
    extractor = ClaimExtractor(provider="openai_compat")
    extraction = await extractor.extract(SAMPLE_TEXT, source_type="url")

    context_agent = ContextAgent(use_mock=True)
    source_agent  = SourceCredibilityAgent()

    context    = await context_agent.run(nfo, extraction.claims)
    source     = await source_agent.run(nfo)
    network    = analyse_network(source_type="url", url="https://example-news.xyz/story",
                                 extracted_text=SAMPLE_TEXT)
    linguistic = analyse_linguistics(extracted_text=SAMPLE_TEXT,
                                     title="Breaking Fusion Energy News",
                                     source_type="url")

    # Build a mock ClaimVerifyResult (avoids needing a live vector DB)
    from Agents.claim_verifier import ClaimVerifyResult
    mock_verify = ClaimVerifyResult(
        input_type="URL",
        source_ref="test_source",
        dedup_hash="a" * 64,
        quality_passed=True,
        claims=extraction.claims,
        verified_claims=[],
        retrieved_chunks=[],
        overall_support_score=0.2,
        overall_contradiction_score=0.6,
        agent_errors=[],
    )

    result: FusionResult = fuse_evidence(
        nfo=nfo,
        claim_extraction=extraction,
        claim_verification=mock_verify,
        source_cred=source,
        image_forensics=None,   # not an image
        video_forensics=None,   # not a video
        context=context,
        network=network,
        linguistic=linguistic,
    )

    check("risk_score",      result.risk_score,      0.0 <= result.risk_score <= 1.0)
    check("risk_band",       result.risk_band,        result.risk_band in ("GREEN","AMBER","ORANGE","RED"))
    check("ensemble_score",  result.ensemble_score,   0.0 <= result.ensemble_score <= 1.0)
    check("bayesian_score",  result.bayesian_score,   0.0 <= result.bayesian_score <= 1.0)
    check("meta_confidence", result.meta_confidence,  0.0 <= result.meta_confidence <= 1.0)
    check("signals_count",   len(result.signals),     len(result.signals) == 8)
    ok("red_flags_count",    len(result.red_flags))
    ok("key_reasoning",      len(result.key_reasoning))

    # Decision engine
    engine = DecisionEngine()
    decision: PipelineResult = engine.decide(result)

    check("action", decision.action,
          decision.action in ("auto-allow", "flag-review", "auto-block"))
    check("label",  decision.label,  bool(decision.label))
    check("audit_trail_keys", list(decision.audit_trail.keys()),
          "per_agent" in decision.audit_trail)

    ok("decision_action",    decision.action)
    ok("decision_risk_score", decision.risk_score)
    ok("requires_human",     decision.requires_human_review)

    print(f"\n  {PASS} — EvidenceFusion + DecisionEngine OK")
    _results["EvidenceFusion"] = "PASS"



    nfo       = _make_nfo("url")
    extractor = _make_heuristic_extractor()
    extraction = await extractor.extract(SAMPLE_TEXT, source_type="url")

    context = await ContextAgent(use_mock=True).run(nfo, extraction.claims)
    source  = await SourceCredibilityAgent().run(nfo)
    network  = analyse_network(source_type="url", url="https://example-news.xyz/story",
                                extracted_text=SAMPLE_TEXT)
    linguistic = analyse_linguistics(extracted_text=SAMPLE_TEXT,
                                     title="Breaking Fusion Energy News", source_type="url")

    mock_verify = ClaimVerifyResult(
        input_type="URL", source_ref="test_source", dedup_hash="a"*64,
        quality_passed=True, claims=extraction.claims, verified_claims=[],
        retrieved_chunks=[], overall_support_score=0.2,
        overall_contradiction_score=0.6, agent_errors=[],
    )

    result: FusionResult = fuse_evidence(
        nfo=nfo, claim_extraction=extraction, claim_verification=mock_verify,
        source_cred=source, image_forensics=None, video_forensics=None,
        context=context, network=network, linguistic=linguistic,
    )

    check("risk_score 0-1",     result.risk_score,      0.0 <= result.risk_score <= 1.0)
    check("risk_band",          result.risk_band,        result.risk_band in ("GREEN","AMBER","ORANGE","RED"))
    check("ensemble 0-1",       result.ensemble_score,   0.0 <= result.ensemble_score <= 1.0)
    check("bayesian 0-1",       result.bayesian_score,   0.0 <= result.bayesian_score <= 1.0)

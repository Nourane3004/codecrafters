# ── ANSI colours ──────────────────────────────────────────────────
GREEN  = "\033[92m"; YELLOW = "\033[93m"; RED    = "\033[91m"
CYAN   = "\033[96m"; BOLD   = "\033[1m";  RESET  = "\033[0m"
PASS = f"{GREEN}PASS{RESET}"; SKIP = f"{YELLOW}SKIP{RESET}"; FAIL = f"{RED}FAIL{RESET}"

_results: dict[str, str] = {}

